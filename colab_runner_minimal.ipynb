    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# MPT Agent System - Gemini Colab Runner\n",
        "\n",
        "Runtime: Standard (CPU). No GPU required.\n",
        "\n",
        "Pipeline: TrendScout -> ScriptWriter (Gemini). VideoProducer/SEO/Publisher steps are skipped in this minimal notebook."
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## Step 1 - Install dependencies and clone repos"]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "step1_install"},
      "source": [
        "import os\n",
        "\n",
        "print('Installing system packages (imagemagick, ffmpeg)...')\n",
        "!apt-get install -y -q imagemagick ffmpeg > /dev/null 2>&1\n",
        "# Relax ImageMagick policy for Colab\n",
        "!sed -i 's/rights=\\"none\\" pattern=\\"PDF\\"/rights=\\"read|write\\" pattern=\\"PDF\\"/g' /etc/ImageMagick-6/policy.xml 2>/dev/null || true\n",
        "\n",
        "# Clone MoneyPrinterTurbo\n",
        "if not os.path.exists('/content/MoneyPrinterTurbo'):\n",
        "    !git clone --depth 1 https://github.com/harry0703/MoneyPrinterTurbo.git /content/MoneyPrinterTurbo\n",
        "else:\n",
        "    !cd /content/MoneyPrinterTurbo && git pull --quiet\n",
        "print('MoneyPrinterTurbo ready')\n",
        "\n",
        "# Install MPT Python dependencies\n",
        "!pip install -q -r /content/MoneyPrinterTurbo/requirements.txt 2>&1 | tail -5\n",
        "!pip install -q loguru edge-tts moviepy imageio-ffmpeg toml feedparser pytrends requests google-api-python-client google-auth-httplib2 google-auth-oauthlib 2>&1 | tail -5\n",
        "\n",
        "# Clone agent system\n",
        "if not os.path.exists('/content/mpt-agent-system'):\n",
        "    !git clone --depth 1 https://github.com/Bhushan-Khachane/mpt-agent-system.git /content/mpt-agent-system\n",
        "else:\n",
        "    !cd /content/mpt-agent-system && git pull\n",
        "\n",
        "print('All dependencies installed.')"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Step 2 - Configure environment (API keys) and choose niche\n",
        "\n",
        "- Gemini API key (starts with AIza): https://aistudio.google.com/app/apikey\n",
        "- Pexels/Pixabay keys are NOT required in this minimal pipeline because we only run TrendScout + ScriptWriter."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "step2_config"},
      "source": [
        "import os, sys, pathlib\n",
        "\n",
        "# EDIT THESE VALUES\n",
        "GEMINI_API_KEY  = 'AIza...'          # required\n",
        "GEMINI_MODEL    = 'gemini-2.0-flash' # or 'gemma-4-31b-it'\n",
        "MANUAL_NICHE    = 'ai_tech'          # manually choose: 'ai_tech', 'home_cleaning', or 'money_mindset'\n",
        "\n",
        "# Strip whitespace to avoid invisible spaces/newlines\n",
        "GEMINI_API_KEY  = GEMINI_API_KEY.strip()\n",
        "GEMINI_MODEL    = GEMINI_MODEL.strip()\n",
        "MANUAL_NICHE    = MANUAL_NICHE.strip()\n",
        "\n",
        "if not GEMINI_API_KEY or GEMINI_API_KEY == 'AIza...':\n",
        "    raise ValueError('Gemini API key is empty. Paste your key as a plain string, e.g. \\\'AIza...\\\'.')\n",
        "if MANUAL_NICHE not in {'ai_tech','home_cleaning','money_mindset'}:\n",
        "    raise ValueError(f'MANUAL_NICHE must be one of ai_tech, home_cleaning, money_mindset, got: {MANUAL_NICHE}')\n",
        "\n",
        "os.environ['GEMINI_API_KEY'] = GEMINI_API_KEY\n",
        "os.environ['GEMINI_MODEL']   = GEMINI_MODEL\n",
        "\n",
        "AGENT_ROOT = '/content/mpt-agent-system'\n",
        "if AGENT_ROOT not in sys.path:\n",
        "    sys.path.insert(0, AGENT_ROOT)\n",
        "\n",
        "for d in ['data', 'logs']:\n",
        "    pathlib.Path(f'{AGENT_ROOT}/{d}').mkdir(parents=True, exist_ok=True)\n",
        "for fp, default in [\n",
        "    (f'{AGENT_ROOT}/data/topics_queue.json', '[]'),\n",
        "    (f'{AGENT_ROOT}/data/seen_topics.json',  '[]'),\n",
        "]:\n",
        "    p = pathlib.Path(fp)\n",
        "    if not p.exists():\n",
        "        p.write_text(default)\n",
        "\n",
        "print('Config OK')\n",
        "print('Gemini key prefix:', GEMINI_API_KEY[:12] + '...')\n",
        "print('Model:', GEMINI_MODEL)\n",
        "print('Manual niche:', MANUAL_NICHE)"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## Step 3 - Run TrendScout for the chosen niche"]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "step3_trends"},
      "source": [
        "import importlib, sys, json, pathlib\n",
        "\n",
        "from agents.trend_scout import run_trend_scout\n",
        "\n",
        "AGENT_ROOT = '/content/mpt-agent-system'\n",
        "qf = pathlib.Path(f'{AGENT_ROOT}/data/topics_queue.json')\n",
        "queue_before = json.loads(qf.read_text()) if qf.exists() else []\n",
        "print('Queue size before:', len(queue_before))\n",
        "\n",
        "topics = run_trend_scout(niche=MANUAL_NICHE)\n",
        "\n",
        "queue_after = json.loads(qf.read_text())\n",
        "print('Queue file:', qf)\n",
        "print('New topics added this run:', len(topics))\n",
        "print('Total topics in queue now:', len(queue_after))\n",
        "print('\nSample topics in chosen niche:')\n",
        "for t in topics[:5]:\n",
        "    print('-', t['niche'], '|', t['title'][:80])"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## Step 4 - Run ScriptWriter (Gemini) for pending topics in chosen niche"]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "step4_scripts"},
      "source": [
        "import importlib, sys, json, pathlib\n",
        "\n",
        "from agents.script_writer import run_script_writer\n",
        "\n",
        "AGENT_ROOT = '/content/mpt-agent-system'\n",
        "qf = pathlib.Path(f'{AGENT_ROOT}/data/topics_queue.json')\n",
        "queue_before = json.loads(qf.read_text()) if qf.exists() else []\n",
        "pending_in_niche = [t for t in queue_before if t.get('status') == 'pending' and t.get('niche') == MANUAL_NICHE]\n",
        "print('Pending topics in niche before:', len(pending_in_niche))\n",
        "\n",
        "n = run_script_writer(batch_size=5)\n",
        "\n",
        "queue_after = json.loads(qf.read_text())\n",
        "scripted = [t for t in queue_after if t.get('status') == 'scripted' and t.get('niche') == MANUAL_NICHE]\n",
        "failed   = [t for t in queue_after if t.get('status') == 'script_failed' and t.get('niche') == MANUAL_NICHE]\n",
        "print('Scripts written this run:', n)\n",
        "print('Total scripted topics in chosen niche:', len(scripted))\n",
        "print('Script failures in chosen niche:', len(failed))\n",
        "if scripted:\n",
        "    t0 = scripted[0]\n",
        "    print('\nSample scripted topic:')\n",
        "    print('Niche :', t0['niche'])\n",
        "    print('Title :', t0['title'])\n",
        "    print('Script:\n', t0['script'])"
      ],
      "execution_count": null,
      "outputs": []
    }
  ]
}
