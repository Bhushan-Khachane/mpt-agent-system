# ── Gemini (required) ─────────────────────────────────────────────────────
# Get a free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# ── MPT (MoneyPrinterTurbo) ───────────────────────────────────────────────
MPT_DIR=/Users/YOUR_USER/MoneyPrinterTurbo
MPT_API_URL=http://localhost:8080
MPT_USE_API=false

# ── Stock media (free) ────────────────────────────────────────────────────
# Pexels: https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_key
# Pixabay: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your_pixabay_key

# ── YouTube Channels ───────────────────────────────────────────────────────
YT_CHANNEL_AI=UCxxxxxxxxxxxxxx
YT_CHANNEL_CLEAN=UCxxxxxxxxxxxxxx
YT_CHANNEL_MONEY=UCxxxxxxxxxxxxxx

# ── Instagram Accounts ─────────────────────────────────────────────────────
IG_ACCOUNT_AI=your_ai_instagram_account
IG_ACCOUNT_CLEAN=your_cleaning_instagram_account
IG_ACCOUNT_MONEY=your_money_instagram_account

# ── Facebook Pages ─────────────────────────────────────────────────────────
FB_PAGE_AI=your_fb_page_id
FB_PAGE_CLEAN=your_fb_page_id
FB_PAGE_MONEY=your_fb_page_id

# ── Upload-Post.com ───────────────────────────────────────────────────────
UPLOAD_POST_API_KEY=your_upload_post_key
