  "cells": [
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "# \ud83c\udfac MPT Agent System \u2014 Gemini Colab Runner\n",
        "\n",
        "**Runtime: Standard (CPU only)** \u2014 No GPU needed.\n",
        "\n",
        "Pipeline: **TrendScout \u2192 ScriptWriter (Gemini) \u2192 VideoProducer (MPT) \u2192 SEO (Gemini) \u2192 Publisher**\n",
        "\n",
        "---"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## \u2705 Step 1 \u2014 Clone repos and install dependencies"]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "step1_install"},
      "source": [
        "import os\n",
        "\n",
        "# 1a. Clone MoneyPrinterTurbo\n",
        "if not os.path.exists('/content/MoneyPrinterTurbo'):\n",
        "    !git clone --depth 1 https://github.com/harry0703/MoneyPrinterTurbo.git /content/MoneyPrinterTurbo\n",
        "else:\n",
        "    !cd /content/MoneyPrinterTurbo && git pull --quiet\n",
        "print('MPT cloned.')\n",
        "\n",
        "# 1b. Install MPT dependencies\n",
        "!pip install -q -r /content/MoneyPrinterTurbo/requirements.txt 2>&1 | tail -5\n",
        "!pip install -q loguru edge-tts imageio-ffmpeg 'moviepy==1.0.3' 2>&1 | tail -3\n",
        "\n",
        "# 1c. Clone agent system\n",
        "if not os.path.exists('/content/mpt-agent-system'):\n",
        "    !git clone --depth 1 https://github.com/Bhushan-Khachane/mpt-agent-system.git /content/mpt-agent-system\n",
        "else:\n",
        "    print('Pulling latest agent system...')\n",
        "    !cd /content/mpt-agent-system && git pull\n",
        "\n",
        "# 1d. Install agent dependencies\n",
        "!pip install -q feedparser pytrends requests google-api-python-client google-auth-httplib2 google-auth-oauthlib 2>&1 | tail -3\n",
        "\n",
        "print('\\n\u2705 All dependencies installed.')"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## \ud83d\udd11 Step 2 \u2014 Paste your API keys\n",
        "\n",
        "- **Gemini (free, key starts with `AIza`):** https://aistudio.google.com/app/apikey\n",
        "- **Pexels (free):** https://www.pexels.com/api/\n"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "step2_config"},
      "source": [
        "import os, sys, pathlib\n",
        "\n",
        "# \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n",
        "GEMINI_API_KEY  = 'AIza...'          # <-- your Gemini key (starts with AIza)\n",
        "PEXELS_API_KEY  = 'YOUR_PEXELS_KEY'  # <-- your Pexels key\n",
        "PIXABAY_API_KEY = ''                 # optional\n",
        "# \u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\u2550\n",
        "\n",
        "# Validate Gemini key format (MUST start with AIza)\n",
        "if not GEMINI_API_KEY.startswith('AIza') or len(GEMINI_API_KEY) < 20:\n",
        "    raise ValueError(\n",
        "        'ERROR: Invalid Gemini key format.\\n'\n",
        "        'Real Gemini keys start with AIza and are ~39 chars.\\n'\n",
        "        'Get yours FREE at: https://aistudio.google.com/app/apikey'\n",
        "    )\n",
        "if PEXELS_API_KEY in {'YOUR_PEXELS_KEY', '', None}:\n",
        "    raise ValueError('ERROR: Paste your Pexels key. Free at https://www.pexels.com/api/')\n",
        "\n",
        "# Set env vars\n",
        "os.environ['GEMINI_API_KEY']   = GEMINI_API_KEY\n",
        "os.environ['GEMINI_MODEL']     = 'gemini-2.0-flash'\n",
        "os.environ['PEXELS_API_KEY']   = PEXELS_API_KEY\n",
        "os.environ['PIXABAY_API_KEY']  = PIXABAY_API_KEY\n",
        "os.environ['MPT_DIR']          = '/content/MoneyPrinterTurbo'\n",
        "os.environ['YT_CHANNEL_AI']    = 'UCxxxxxxxx'\n",
        "os.environ['YT_CHANNEL_CLEAN'] = 'UCxxxxxxxx'\n",
        "os.environ['YT_CHANNEL_MONEY'] = 'UCxxxxxxxx'\n",
        "\n",
        "# Add agent system to Python path\n",
        "AGENT_ROOT = '/content/mpt-agent-system'\n",
        "if AGENT_ROOT not in sys.path:\n",
        "    sys.path.insert(0, AGENT_ROOT)\n",
        "\n",
        "# Create directories and seed empty data files\n",
        "for d in ['data', 'videos', 'logs', 'credentials']:\n",
        "    pathlib.Path(f'{AGENT_ROOT}/{d}').mkdir(parents=True, exist_ok=True)\n",
        "for fp, default in [\n",
        "    (f'{AGENT_ROOT}/data/topics_queue.json', '[]'),\n",
        "    (f'{AGENT_ROOT}/data/seen_topics.json',  '[]'),\n",
        "]:\n",
        "    p = pathlib.Path(fp)\n",
        "    if not p.exists():\n",
        "        p.write_text(default)\n",
        "\n",
        "print(f'\u2705 Config OK | Model={os.environ[\"GEMINI_MODEL\"]} | Key={GEMINI_API_KEY[:12]}...')"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## \ud83d\udd0d Step 2b \u2014 Sanity check paths (run once to verify)"]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "step2b_debug"},
      "source": [
        "# Run this cell to verify all paths are correct before proceeding\n",
        "import pathlib, json, os\n",
        "\n",
        "AGENT_ROOT = '/content/mpt-agent-system'\n",
        "queue_file = pathlib.Path(f'{AGENT_ROOT}/data/topics_queue.json')\n",
        "seen_file  = pathlib.Path(f'{AGENT_ROOT}/data/seen_topics.json')\n",
        "\n",
        "print('=== PATH CHECK ===')\n",
        "print(f'Agent root exists : {pathlib.Path(AGENT_ROOT).exists()}')\n",
        "print(f'Queue file        : {queue_file} ({\"exists\" if queue_file.exists() else \"MISSING\"})')\n",
        "print(f'Seen file         : {seen_file}  ({\"exists\" if seen_file.exists() else \"MISSING\"})')\n",
        "print(f'MPT dir           : {os.environ.get(\"MPT_DIR\",\"NOT SET\")} ({\"exists\" if pathlib.Path(os.environ.get(\"MPT_DIR\",\"")).exists() else \"MISSING\"})')\n",
        "print(f'MPT cli.py        : {pathlib.Path(os.environ.get(\"MPT_DIR\",\"")) / \"cli.py\"} ({\"exists\" if (pathlib.Path(os.environ.get(\"MPT_DIR\",\"")) / \"cli.py\").exists() else \"MISSING\"})')\n",
        "print(f'Gemini key set    : {bool(os.environ.get(\"GEMINI_API_KEY\",\"").startswith(\"AIza\"))}')\n",
        "print(f'Pexels key set    : {bool(os.environ.get(\"PEXELS_API_KEY\",\""))}')\n",
        "print()\n",
        "\n",
        "# Quick Gemini API test\n",
        "print('=== GEMINI API TEST ===')\n",
        "try:\n",
        "    import requests\n",
        "    key   = os.environ['GEMINI_API_KEY']\n",
        "    model = os.environ['GEMINI_MODEL']\n",
        "    r = requests.post(\n",
        "        f'https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={key}',\n",
        "        json={'contents': [{'parts': [{'text': 'Say OK in 2 words'}]}],\n",
        "              'generationConfig': {'maxOutputTokens': 10}},\n",
        "        timeout=15\n",
        "    )\n",
        "    r.raise_for_status()\n",
        "    reply = r.json()['candidates'][0]['content']['parts'][0]['text']\n",
        "    print(f'\u2705 Gemini responded: {reply.strip()}')\n",
        "except Exception as e:\n",
        "    print(f'\u274c Gemini API FAILED: {e}')\n",
        "    print('  --> Get a valid key at https://aistudio.google.com/app/apikey')"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## \ud83d\udcc8 Step 3 \u2014 TrendScout"]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "step3_trends"},
      "source": [
        "# Reload to pick up any code changes from git pull\n",
        "import importlib, agents.trend_scout as ts\n",
        "importlib.reload(ts)\n",
        "from agents.trend_scout import run_trend_scout\n",
        "import json, pathlib\n",
        "\n",
        "topics = run_trend_scout()\n",
        "\n",
        "# Verify the queue was written to the CORRECT location\n",
        "queue_path = pathlib.Path('/content/mpt-agent-system/data/topics_queue.json')\n",
        "queue      = json.loads(queue_path.read_text())\n",
        "pending    = [t for t in queue if t.get('status') == 'pending']\n",
        "\n",
        "print(f'\\n\ud83d\udccb Queue file: {queue_path}')\n",
        "print(f'   Total items  : {len(queue)}')\n",
        "print(f'   Pending items: {len(pending)} \u2190 ScriptWriter will process these')\n",
        "print('\\nTop 5:')\n",
        "for t in pending[:5]:\n",
        "    print(f\"  [{t['niche']:12s}] {t['title'][:55]} (score={t.get('score_val',0):.1f})\")"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## \u270d\ufe0f Step 4 \u2014 ScriptWriter (Gemini API)\n",
        "> Generates ~50-80 word narration scripts per topic via Gemini."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "step4_scripts"},
      "source": [
        "import importlib, agents.script_writer as sw\n",
        "importlib.reload(sw)\n",
        "from agents.script_writer import run_script_writer\n",
        "import json, pathlib\n",
        "\n",
        "n = run_script_writer(batch_size=6)\n",
        "print(f'\\n\u2705 {n} scripts written')\n",
        "\n",
        "queue    = json.loads(pathlib.Path('/content/mpt-agent-system/data/topics_queue.json').read_text())\n",
        "scripted = [t for t in queue if t.get('status') == 'scripted']\n",
        "print(f'Scripted in queue: {len(scripted)}')\n",
        "if scripted:\n",
        "    t0 = scripted[0]\n",
        "    print(f\"\\n--- Sample ({t0['niche']}) ---\")\n",
        "    print(t0['script'])\n",
        "else:\n",
        "    print('\\n\u274c No scripted topics! Check Step 2b Gemini test for API errors.')"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## \ud83c\udfac Step 5 \u2014 VideoProducer (MPT CLI + Pexels stock footage)\n",
        "> Calls `python cli.py` inside MoneyPrinterTurbo. Each video takes 2-5 min."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "step5_video"},
      "source": [
        "import importlib, agents.video_producer as vp\n",
        "importlib.reload(vp)\n",
        "from agents.video_producer import run_video_producer\n",
        "run_video_producer(batch_size=1)  # Start with 1 to test first"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## \ud83c\udff7\ufe0f Step 6 \u2014 SEO Agent (Gemini API)"]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "step6_seo"},
      "source": [
        "import importlib, agents.seo_agent as sa\n",
        "importlib.reload(sa)\n",
        "from agents.seo_agent import run_seo_agent\n",
        "run_seo_agent(batch_size=6)"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## \ud83d\udce4 Step 7 \u2014 Publisher\n",
        "> Without a YouTube OAuth token, videos go to `data/manual_upload_queue.json`."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "step7_publish"},
      "source": [
        "import importlib, agents.publisher as pub\n",
        "importlib.reload(pub)\n",
        "from agents.publisher import run_publisher\n",
        "run_publisher(batch_size=3)"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## \ud83d\udccb Pipeline status"]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "check_status"},
      "source": [
        "import json, pathlib\n",
        "from collections import Counter\n",
        "\n",
        "queue_path = pathlib.Path('/content/mpt-agent-system/data/topics_queue.json')\n",
        "queue  = json.loads(queue_path.read_text())\n",
        "counts = Counter(t.get('status','unknown') for t in queue)\n",
        "print(f'Queue file: {queue_path} ({len(queue)} items)')\n",
        "print('\\nStatus breakdown:')\n",
        "for status, n in sorted(counts.items()):\n",
        "    print(f'  {status:30s}: {n}')\n",
        "\n",
        "# Show any failed items\n",
        "failed = [t for t in queue if 'failed' in t.get('status','')]\n",
        "if failed:\n",
        "    print(f'\\n\u26a0\ufe0f {len(failed)} failed items:')\n",
        "    for t in failed[:3]:\n",
        "        print(f\"  [{t['niche']}] {t['title'][:50]}\")\n",
        "        print(f\"  Error: {t.get('error','?')[:120]}\")\n",
        "\n",
        "# Show videos ready for manual upload\n",
        "manual = pathlib.Path('/content/mpt-agent-system/data/manual_upload_queue.json')\n",
        "if manual.exists():\n",
        "    items = json.loads(manual.read_text())\n",
        "    if items:\n",
        "        print(f'\\n\ud83d\udcc1 {len(items)} videos ready for manual upload')\n",
        "        for v in items[-3:]:\n",
        "            print(f\"  [{v['niche']}] {v['title'][:50]}\")\n",
        "            print(f\"  File     : {v['video_path']}\")\n",
        "            print(f\"  YT Title : {v['youtube_title']}\")\n",
        "            print()"
      ],
      "execution_count": null,
      "outputs": []
    }
  ]
