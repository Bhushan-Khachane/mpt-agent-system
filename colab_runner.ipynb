    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": ["## 🗂️ Pipeline status"]
    },
    {
      "cell_type": "code",
      "metadata": {"id": "check_status"},
      "source": [
        "import json, pathlib\n",
        "from collections import Counter\n",
        "\n",
        "qf     = pathlib.Path('/content/mpt-agent-system/data/topics_queue.json')\n",
        "queue  = json.loads(qf.read_text())\n",
        "counts = Counter(t.get('status','unknown') for t in queue)\n",
        "\n",
        "print(f'Queue: {qf}  ({len(queue)} items)')\n",
        "print('\nStatus breakdown:')\n",
        "for status, n in sorted(counts.items()):\n",
        "    print(f'  {status:30s}: {n}')\n",
        "\n",
        "# Show errors if any\n",
        "failed = [t for t in queue if 'failed' in t.get('status','')]\n",
        "if failed:\n",
        "    print(f'\n⚠️ {len(failed)} failed items (showing first 3):')\n",
        "    for t in failed[:3]:\n",
        "        print(f"  [{t['niche']}] {t['title'][:50]}")\n",
        "        print(f"  Error: {str(t.get('error','?'))[:150]}")\n",
        "\n",
        "# Show generated videos\n",
        "videos = list(pathlib.Path('/content/mpt-agent-system/videos').glob('*.mp4'))\n",
        "if videos:\n",
        "    print(f'\n🎬 {len(videos)} videos generated:')\n",
        "    for v in videos:\n",
        "        size_mb = v.stat().st_size / 1024 / 1024\n",
        "        print(f'  {v.name}  ({size_mb:.1f} MB)')\n",
        "\n",
        "# Show manual upload queue\n",
        "mf = pathlib.Path('/content/mpt-agent-system/data/manual_upload_queue.json')\n",
        "if mf.exists():\n",
        "    items = json.loads(mf.read_text())\n",
        "    if items:\n",
        "        print(f'\n📁 {len(items)} videos ready for manual upload:')\n",
        "        for v in items[-3:]:\n",
        "            print(f"  [{v['niche']}] {v['youtube_title']}")\n",
        "            print(f"  File: {v['video_path']}")"
      ],
      "execution_count": null,
      "outputs": []
    }
